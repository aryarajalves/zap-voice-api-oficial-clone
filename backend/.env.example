# ========================================
# ZapVoice - Backend Configuração (.env.example)
# ========================================
# Copie este arquivo para .env na pasta backend e preencha com as credenciais do seu projeto.
# Este arquivo é a fonte de verdade para o setup do projeto.

# === WhatsApp Oficial (Meta Cloud API) ===
# [OPCIONAL] Credenciais para comunicação com a API do WhatsApp Business da Meta
WA_BUSINESS_ACCOUNT_ID=seu_business_account_id_aqui
WA_PHONE_NUMBER_ID=seu_phone_number_id_aqui
WA_ACCESS_TOKEN=seu_token_de_acesso_permanente_aqui

# === Chatwoot ===
# [OPCIONAL] Configurações para integração com Chatwoot
CHATWOOT_API_URL=https://seu-chatwoot.com/api/v1
CHATWOOT_API_TOKEN=seu_token_chatwoot
CHATWOOT_ACCOUNT_ID=1
CHATWOOT_SELECTED_INBOX_ID=1

# === Baserow (CRM) ===
# [OPCIONAL] Integração legada com Baserow
BASEROW_API_URL=https://seu-baserow.com
BASEROW_TOKEN=seu_token_baserow
BASEROW_TABLE_ID=123

# === URLs da Aplicação ===
# [OBRIGATÓRIO] URLs de API, WebSocket e Webhook
VITE_API_URL=https://seu-dominio.com
VITE_WS_URL=wss://seu-dominio.com
WEBHOOK_BASE_URL=https://seu-dominio.com

# === PostgreSQL ===
# [OBRIGATÓRIO] URL de conexão com o banco de dados PostgreSQL
DATABASE_URL=postgresql://postgres:senha_segura@postgres:5432/zapvoice_production

# === Segurança ===
# [OBRIGATÓRIO] Chave secreta JWT (mínimo 32 caracteres) e Token de Verificação do Webhook da Meta
SECRET_KEY=troque_isso_por_uma_chave_aleatoria_segura_de_mais_de_32_caracteres
WHATSAPP_VERIFY_TOKEN=seu_webhook_token_2026
REGISTER_API_KEY=sua_chave_secreta_para_registrar_123

# === CORS ===
# [OPCIONAL] Origens permitidas para requisições cross-origin (separadas por vírgula)
CORS_ORIGINS=https://seu-dominio.com,https://seu-outro-dominio.com

# === RabbitMQ ===
# [OBRIGATÓRIO] Conexão com o RabbitMQ local para filas de mensagens e tarefas
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# === Fuso Horário e Porta ===
# [OBRIGATÓRIO] Fuso horário do sistema e porta de execução
TZ=America/Sao_Paulo
PORT=8000

# === Cloud Storage (S3 / Backblaze) ===
# [OPCIONAL] Configurações para uploads de arquivos de mídia
S3_BUCKET_NAME=zapvoice-files
S3_ENDPOINT_URL=https://s3.us-west-004.backblazeb2.com
S3_ACCESS_KEY=chave_de_acesso
S3_SECRET_KEY=chave_secreta
S3_REGION=us-west-004
S3_PUBLIC_URL=https://zap-voice.s3.us-west-004.backblazeb2.com

# === Limites de Taxa (Rate Limiting) ===
# [OPCIONAL] Define se o limitador de taxa (slowapi) deve estar ativo.
# Defina como "false" para executar testes de integração sem bloqueio por 429.
RATE_LIMIT_ENABLED=true

# === Retenção de Dados ===
# [OPCIONAL] Dias para manter histórico no banco e nos logs do container
HISTORY_RETENTION_DAYS=30
LOG_RETENTION_DAYS=7

# === Super Admin Inicial ===
# [OBRIGATÓRIO] Credenciais criadas automaticamente no boot do backend
SUPER_ADMIN_EMAIL=aryarajmarketing@gmail.com
SUPER_ADMIN_PASSWORD=123456
